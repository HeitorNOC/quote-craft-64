# SerpAPI Configuration
# Get your free API key at: https://serpapi.com/
# Free tier includes 100 credits (≈ 20 Home Depot searches)
SERPAPI_API_KEY=your_serpapi_key_here

# Example with real key:
# SERPAPI_API_KEY=abc123def456...

# Email Configuration
# Resend API Key - Get at: https://resend.com/
RESEND_API_KEY=your_resend_api_key_here

# Backend email where contact form submissions will be sent
VITE_JD_COMPANY_EMAIL=contact@jdflooringcleaningservicesllc.com

# Google Sheets Configuration for Estimates
# 1. Create Google Cloud project and enable Sheets API
# 2. Create Service Account and download JSON credentials
# 3. Convert credentials to base64: cat credentials.json | base64 | pbcopy
GOOGLE_SERVICE_ACCOUNT=base64_encoded_service_account_credentials_here
# Separate spreadsheets for flooring and cleaning
GOOGLE_FLOORING_SPREADSHEET_ID=1slAPvDPcic5XVNPnvG3A6U2cE-L-HIeZL_KHhTUrQwY
GOOGLE_CLEANING_SPREADSHEET_ID=1ljSf3MyC4tey74rxyCFBDwS5NePTELajMRclZN0U_wQ
